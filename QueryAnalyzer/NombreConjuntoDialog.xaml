<Window x:Class="QueryAnalyzer.NombreConjuntoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva isla"
        Width="340" Height="153"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushWindowBG}"
        Foreground="{DynamicResource BrushFG}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ThemeLight.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Nombre del conjunto:"
                   Foreground="{DynamicResource BrushFG}"/>

        <TextBox x:Name="txtNombre"
                 Grid.Row="2"
                 Background="{DynamicResource BrushControlBG}"
                 Foreground="{DynamicResource BrushFG}"
                 BorderBrush="{DynamicResource BrushBorder}"
                 BorderThickness="1"
                 Padding="4,2"
                 KeyDown="TxtNombre_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Aceptar"
                    Width="80"
                    Margin="0,0,8,0"
                    Background="{DynamicResource BrushBtnBG}"
                    Foreground="{DynamicResource BrushFG}"
                    BorderBrush="{DynamicResource BrushBtnBorder}"
                    Click="BtnAceptar_Click"/>
            <Button Content="Cancelar"
                    Width="80"
                    IsCancel="True"
                    Background="{DynamicResource BrushBtnBG}"
                    Foreground="{DynamicResource BrushFG}"
                    BorderBrush="{DynamicResource BrushBtnBorder}"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
