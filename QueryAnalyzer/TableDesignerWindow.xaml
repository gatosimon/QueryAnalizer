<Window x:Class="QueryAnalyzer.TableDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Design"
        Width="820" Height="520"
        MinWidth="520" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushWindowBG}"
        Foreground="{DynamicResource BrushFG}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Tema inicial claro; el code-behind aplica el tema activo de MainWindow en Loaded. -->
                <ResourceDictionary Source="ThemeLight.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- ── Estilos implícitos temáticos ── -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Background"     Value="{DynamicResource BrushControlBG}"/>
                <Setter Property="Foreground"     Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush"    Value="{DynamicResource BrushBorder}"/>
                <Setter Property="CaretBrush"     Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"        Value="3,2"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background"     Value="{DynamicResource BrushBtnBG}"/>
                <Setter Property="Foreground"     Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush"    Value="{DynamicResource BrushBtnBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"        Value="6,3"/>
            </Style>
            <Style TargetType="ContextMenu">
                <Setter Property="Background"  Value="{DynamicResource BrushMenuBG}"/>
                <Setter Property="Foreground"  Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            </Style>
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="{DynamicResource BrushMenuBG}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background" Value="{DynamicResource BrushMenuHover}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BrushSelectedFG}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background"               Value="{DynamicResource BrushPanelBG}"/>
                <Setter Property="Foreground"               Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush"              Value="{DynamicResource BrushBorder}"/>
                <Setter Property="RowBackground"            Value="{DynamicResource BrushControlBG}"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource BrushAltRowBG}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BrushBorder}"/>
                <Setter Property="VerticalGridLinesBrush"   Value="{DynamicResource BrushBorder}"/>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{DynamicResource BrushFG}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background"  Value="{DynamicResource BrushSelected}"/>
                        <Setter Property="Foreground"  Value="{DynamicResource BrushSelectedFG}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="DataGridRowHeader">
                <Setter Property="Background" Value="{DynamicResource BrushAltRowBG}"/>
            </Style>
            <Style TargetType="StatusBar">
                <Setter Property="Background" Value="{DynamicResource BrushPanelBG}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
            </Style>

            <!-- ── Estilos con clave para el DataGrid del diseñador ── -->
            <Style x:Key="ColHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background"       Value="{DynamicResource BrushHeaderBG}"/>
                <Setter Property="Foreground"       Value="{DynamicResource BrushHeaderFG}"/>
                <Setter Property="BorderBrush"      Value="{DynamicResource BrushBorder}"/>
                <Setter Property="BorderThickness"  Value="0,0,1,1"/>
                <Setter Property="Padding"          Value="6,4"/>
                <Setter Property="FontWeight"       Value="SemiBold"/>
            </Style>

            <!-- Fila marcada para eliminar → rojo semántico; fila nueva → verde semántico.
                 Se mantienen hardcodeados porque son colores de estado, no de tema. -->
            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{DynamicResource BrushControlBG}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding MarcarParaEliminar}" Value="True">
                        <Setter Property="Background" Value="#FFE0E0"/>
                        <Setter Property="Foreground" Value="#CC0000"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding EsNueva}" Value="True">
                        <Setter Property="Background" Value="#E8F5E9"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Celda Column Name en negrita si es PK -->
            <Style x:Key="CeldaNombreStyle" TargetType="TextBlock">
                <Setter Property="Padding"    Value="4,2"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding EsPK}" Value="True">
                        <Setter Property="FontWeight" Value="Bold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CeldaTextoStyle" TargetType="TextBlock">
                <Setter Property="Padding"    Value="4,2"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
            </Style>

            <Style x:Key="CeldaDefaultStyle" TargetType="TextBlock">
                <Setter Property="Padding"    Value="4,2"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFGMuted}"/>
                <Setter Property="FontStyle"  Value="Italic"/>
            </Style>

            <!-- ComboBox de tipos de dato (editable, temático) -->
            <Style TargetType="ComboBox">
                <Setter Property="Background"  Value="{DynamicResource BrushControlBG}"/>
                <Setter Property="Foreground"  Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            </Style>
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="{DynamicResource BrushMenuBG}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background" Value="{DynamicResource BrushMenuHover}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BrushSelectedFG}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">
            <Button x:Name="btnAgregar" Click="AgregarColumna_Click"
                    ToolTip="Agregar nueva columna" Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Nueva columna" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button x:Name="btnScript" Click="GenerarScript_Click"
                    ToolTip="Generar script DDL con los cambios detectados" Padding="6,2">
                <TextBlock Text="Aplicar"/>
            </Button>
            <Separator/>
            <Button x:Name="btnRecargar" Click="Recargar_Click"
                    ToolTip="Recargar desde la base de datos (descarta cambios)" Padding="6,2">
                <TextBlock Text="Recargar"/>
            </Button>
            <Separator/>

            <!-- ── Renombrar tabla ── -->
            <TextBlock Text="Renombrar tabla:" VerticalAlignment="Center"
                       Margin="4,0,6,0" Foreground="{DynamicResource BrushFGMuted}" FontSize="11"/>
            <TextBox x:Name="txtNuevoNombre"
                     Width="140" Padding="4,2"
                     VerticalContentAlignment="Center"
                     ToolTip="Nuevo nombre para la tabla. Dejá vacío para no renombrar."
                     FontSize="11"/>
            <Button x:Name="btnRenombrar" Click="RenombrarTabla_Click" IsEnabled="False"
                    ToolTip="Agregar sentencia RENAME al script" Padding="6,2" Margin="4,0,0,0">
                <TextBlock Text="✏️ Renombrar" VerticalAlignment="Center" Visibility="Hidden"/>
            </Button>
        </ToolBar>

        <!-- ── Panel: Descripción de tabla + Modo de aplicación ── -->
        <Border Grid.Row="1"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BrushBorder}"
                Background="{DynamicResource BrushPanelBG}"
                Padding="10,6,10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Fila 0: Descripción de la tabla -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Descripción:" VerticalAlignment="Center"
                           FontSize="11" Margin="0,0,8,4"
                           Foreground="{DynamicResource BrushFGMuted}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                           x:Name="txtDescripcionTabla"
                           FontSize="11" Margin="0,0,0,4" MaxLength="500"
                           ToolTip="Descripción de la tabla (MS_Description / COMMENT ON TABLE)"/>

                <!-- Fila 1: Modo de aplicación -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Al aplicar:" VerticalAlignment="Center"
                           FontSize="11" Margin="0,0,8,0"
                           Foreground="{DynamicResource BrushFGMuted}"/>
                <RadioButton Grid.Row="1" Grid.Column="1"
                             x:Name="rbRevisarScript"
                             Content="Generar script para revisión"
                             IsChecked="True" GroupName="ModoAplicar"
                             VerticalAlignment="Center" FontSize="11"
                             Foreground="{DynamicResource BrushFG}"
                             ToolTip="El script se cargará en el editor para que lo revises y ejecutes manualmente."/>
                <RadioButton Grid.Row="1" Grid.Column="2"
                             x:Name="rbAplicarDirecto"
                             Content="Aplicar directamente"
                             GroupName="ModoAplicar"
                             VerticalAlignment="Center" FontSize="11" Margin="16,0,0,0"
                             Foreground="{DynamicResource BrushFG}"
                             ToolTip="Los cambios se aplicarán automáticamente contra la base de datos al cerrar."/>
            </Grid>
        </Border>

        <!-- ── DataGrid principal ── -->
        <DataGrid Grid.Row="2" x:Name="dgColumnas"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="24"
                  ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                  BorderThickness="0"
                  Background="{DynamicResource BrushPanelBG}">

            <!-- Header de fila: ícono de llave si es PK -->
            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="🔑" FontSize="10" ToolTip="Clave primaria"
                               Visibility="{Binding DataContext.EsPK,
                                            RelativeSource={RelativeSource AncestorType=DataGridRow},
                                            Converter={StaticResource BoolToVis}}"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>

            <DataGrid.Columns>

                <!-- Column Name -->
                <DataGridTextColumn Header="Column Name" Width="*"
                                    Binding="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                    ElementStyle="{StaticResource CeldaNombreStyle}"/>

                <!-- Data Type: ComboBox editable con los tipos del motor activo.
                     ItemsSource se lee desde Tag del DataGrid (asignado en code-behind). -->
                <DataGridTemplateColumn Header="Data Type" Width="200">

                    <!-- Vista normal (celda no editando) -->
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TipoDatoCompleto}"
                                       Style="{StaticResource CeldaTextoStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <!-- Vista en edición: ComboBox editable -->
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      StaysOpenOnEdit="True"
                                      Text="{Binding TipoDatoCompleto,
                                             UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding Tag,
                                             RelativeSource={RelativeSource
                                             AncestorType=DataGrid}}"
                                      BorderThickness="0"
                                      Padding="2,0"
                                      VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>

                </DataGridTemplateColumn>

                <!-- Allow Nulls -->
                <DataGridCheckBoxColumn Header="Allow Nulls" Width="80"
                                        Binding="{Binding EsNulable, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>

                <!-- Default Value -->
                <DataGridTextColumn Header="Default Value" Width="140"
                                    Binding="{Binding ValorDefault, UpdateSourceTrigger=LostFocus}"
                                    ElementStyle="{StaticResource CeldaDefaultStyle}"/>

                <!-- Descripción -->
                <DataGridTextColumn Header="Descripción" Width="220"
                                    Binding="{Binding Descripcion, UpdateSourceTrigger=LostFocus}"
                                    ElementStyle="{StaticResource CeldaDefaultStyle}"/>

            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Marcar para eliminar" Click="EliminarColumna_Click"/>
                    <MenuItem Header="Desmarcar eliminación"  Click="DesmarcarEliminar_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- ── Status bar ── -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="txtEstado" Text="Listo" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtMotor" FontSize="11" Foreground="{DynamicResource BrushFGMuted}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
