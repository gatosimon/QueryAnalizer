<Window x:Class="QueryAnalyzer.TableDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Design"
        Width="760" Height="520"
        MinWidth="520" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ColHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="#F0F0F0"/>
            <Setter Property="BorderBrush"      Value="#CCCCCC"/>
            <Setter Property="BorderThickness"  Value="0,0,1,1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
        </Style>

        <!-- Fila marcada para eliminar → rojo; fila nueva → verde -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding MarcarParaEliminar}" Value="True">
                    <Setter Property="Background" Value="#FFE0E0"/>
                    <Setter Property="Foreground" Value="#CC0000"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsNueva}" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Celda Column Name en negrita si es PK -->
        <Style x:Key="CeldaNombreStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsPK}" Value="True">
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CeldaTextoStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style x:Key="CeldaDefaultStyle" TargetType="TextBlock">
            <Setter Property="Padding"     Value="4,2"/>
            <Setter Property="Foreground"  Value="#666666"/>
            <Setter Property="FontStyle"   Value="Italic"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">
            <Button x:Name="btnAgregar" Click="AgregarColumna_Click"
                    ToolTip="Agregar nueva columna" Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Nueva columna" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button x:Name="btnScript" Click="GenerarScript_Click"
                    ToolTip="Generar script DDL con los cambios detectados" Padding="6,2">
                <TextBlock Text="Generar script"/>
            </Button>
            <Separator/>
            <Button x:Name="btnRecargar" Click="Recargar_Click"
                    ToolTip="Recargar desde la base de datos (descarta cambios)" Padding="6,2">
                <TextBlock Text="Recargar"/>
            </Button>
        </ToolBar>

        <!-- ── DataGrid principal ── -->
        <DataGrid Grid.Row="1" x:Name="dgColumnas"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="24"
                  ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                  BorderThickness="0"
                  Background="White">

            <!-- Header de fila: ícono de llave si es PK -->
            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="🔑" FontSize="10" ToolTip="Clave primaria"
                               Visibility="{Binding DataContext.EsPK,
                                            RelativeSource={RelativeSource AncestorType=DataGridRow},
                                            Converter={StaticResource BoolToVis}}"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>

            <DataGrid.Columns>

                <!-- Column Name -->
                <DataGridTextColumn Header="Column Name" Width="*"
                                    Binding="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                    ElementStyle="{StaticResource CeldaNombreStyle}"/>

                <!-- Data Type (editable como string: nvarchar(50), decimal(10,2), etc.) -->
                <DataGridTextColumn Header="Data Type" Width="160"
                                    Binding="{Binding TipoDatoCompleto, UpdateSourceTrigger=LostFocus}"
                                    ElementStyle="{StaticResource CeldaTextoStyle}"/>

                <!-- Allow Nulls -->
                <DataGridCheckBoxColumn Header="Allow Nulls" Width="80"
                                        Binding="{Binding EsNulable, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>

                <!-- Default Value -->
                <DataGridTextColumn Header="Default Value" Width="140"
                                    Binding="{Binding ValorDefault, UpdateSourceTrigger=LostFocus}"
                                    ElementStyle="{StaticResource CeldaDefaultStyle}"/>

            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Marcar para eliminar" Click="EliminarColumna_Click"/>
                    <MenuItem Header="Desmarcar eliminación"  Click="DesmarcarEliminar_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- ── Status bar ── -->
        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock x:Name="txtEstado" Text="Listo" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtMotor" FontSize="11" Foreground="#666666"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
