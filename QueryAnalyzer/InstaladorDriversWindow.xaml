<Window x:Class="QueryAnalyzer.InstaladorDriversWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Drivers ODBC"
        Width="700" Height="480"
        MinWidth="580" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BrushWindowBG}"
        Foreground="{DynamicResource BrushFG}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ThemeLight.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource BrushFG}"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background"      Value="{DynamicResource BrushBtnBG}"/>
                <Setter Property="Foreground"      Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource BrushBtnBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="10,4"/>
                <Setter Property="Cursor"          Value="Hand"/>
            </Style>

            <Style TargetType="GroupBox">
                <Setter Property="Foreground"  Value="{DynamicResource BrushFG}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            </Style>
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="{DynamicResource BrushWindowBG}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- encabezado -->
            <RowDefinition Height="*"/>     <!-- lista drivers -->
            <RowDefinition Height="Auto"/>  <!-- barra de estado -->
            <RowDefinition Height="Auto"/>  <!-- botones -->
        </Grid.RowDefinitions>

        <!-- ── Encabezado ─────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Drivers ODBC requeridos por QueryAnalyzer"
                       FontSize="14" FontWeight="SemiBold"/>
            <TextBlock Text="La aplicación es de 32 bits y requiere drivers ODBC de 32 bits. Verifique el estado e instale los faltantes."
                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                       Foreground="{DynamicResource BrushFGMuted}"/>
        </StackPanel>

        <!-- ── Lista de drivers ───────────────────────────────────────────── -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"
                CornerRadius="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource BrushWindowBG}">
                <ItemsControl x:Name="listDrivers" Margin="0"
                              Background="{DynamicResource BrushWindowBG}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>   <!-- icono estado -->
                                    <ColumnDefinition Width="190"/>  <!-- nombre -->
                                    <ColumnDefinition Width="*"/>    <!-- descripción / nota -->
                                    <ColumnDefinition Width="130"/>  <!-- acción -->
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Separador entre filas -->
                                <Border Grid.ColumnSpan="4"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="6,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icono estado -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding IconoEstado}"
                                                   Foreground="{Binding ColorEstado}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Nombre -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,8,0">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding EstadoTexto}"
                                                       FontSize="10"
                                                       Foreground="{Binding ColorEstado}"/>
                                        </StackPanel>

                                        <!-- Descripción y nota -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Descripcion}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Nota}"
                                                       FontSize="10" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource BrushFGMuted}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Botón acción -->
                                        <ContentPresenter Grid.Column="3"
                                                          Content="{Binding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center">
                                            <ContentPresenter.ContentTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <!-- Instalar (bundle disponible y no instalado) -->
                                                        <Button Content="⬇ Instalar"
                                                                Tag="{Binding}"
                                                                Click="BtnInstalar_Click"
                                                                Padding="8,4" FontSize="11"
                                                                Foreground="White"
                                                                Background="#2196F3"
                                                                BorderBrush="#1976D2"
                                                                Visibility="{Binding VisibilidadInstalar}"/>

                                                        <!-- Descargar (fuente externa y no instalado) -->
                                                        <Button Content="🌐 Descargar"
                                                                Tag="{Binding}"
                                                                Click="BtnDescargar_Click"
                                                                Padding="8,4" FontSize="11"
                                                                Foreground="White"
                                                                Background="#FF9800"
                                                                BorderBrush="#F57C00"
                                                                Visibility="{Binding VisibilidadDescargar}"/>

                                                        <!-- Instalado -->
                                                        <TextBlock Text="✔ Listo"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#4CAF50"
                                                                   HorizontalAlignment="Center"
                                                                   Visibility="{Binding VisibilidadListo}"/>

                                                        <!-- Sistema operativo y ya instalado -->
                                                        <TextBlock Text="Parte de Windows"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource BrushFGMuted}"
                                                                   HorizontalAlignment="Center"
                                                                   Visibility="{Binding VisibilidadSO}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ContentPresenter.ContentTemplate>
                                        </ContentPresenter>

                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Barra de estado ────────────────────────────────────────────── -->
        <TextBlock x:Name="txtEstado"
                   Grid.Row="2"
                   Text=""
                   FontSize="11"
                   Foreground="{DynamicResource BrushFGMuted}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>

        <!-- ── Botones ────────────────────────────────────────────────────── -->
        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <Button Content="🔄 Verificar estado"
                    DockPanel.Dock="Left"
                    Padding="10,4"
                    Click="BtnVerificar_Click"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cerrar"
                        IsCancel="True"
                        Padding="12,4"
                        Click="BtnCerrar_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
